SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-socket-mode-token
# Optional. Leave blank to allow any channel the bot has access to.
# Use comma-separated channel IDs to limit where the bot answers.
SLACK_ALLOWED_CHANNEL_IDS=C1234567890,G1234567890

OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-5-mini
VECTOR_STORE_ID=
# Optional. Folder used by scripts/rag-setup.js when no path is provided.
VECTOR_STORE_SOURCE_DIR=vectorstore
# Optional. Rebuild restarts this systemd service on Linux. Must be a simple .service unit name. Use none to disable.
VECTOR_STORE_RESTART_SERVICE=f3po-slack-bot.service
# Optional. Bare domains only, no https://. Leave blank to disable web search.
WEB_SEARCH_ALLOWED_DOMAINS=f3nation.com
# Optional. Daily log files are written here and cleaned up automatically.
LOG_DIR=logs
LOG_RETENTION_DAYS=7
# Optional. error = errors only, info = startup/cleanup/errors, debug = full interactions.
LOG_LEVEL=info

# Optional. BigQuery backblast export settings.
# Install Google Cloud CLI for local auth:
#   brew install --cask google-cloud-sdk
#   gcloud auth application-default login
# Auth uses Google Application Default Credentials or GOOGLE_APPLICATION_CREDENTIALS.
# Set this if gcloud does not have a default project:
#   gcloud config set project YOUR_PROJECT_ID
GOOGLE_CLOUD_PROJECT=f3data
BIGQUERY_BACKBLAST_TABLE=analytics.event_info
BIGQUERY_BACKBLAST_REGION_ORG_ID=36533
BIGQUERY_BACKBLAST_DAYS=90
BIGQUERY_BACKBLAST_OUTPUT=vectorstore/F3 Wichita Documents/f3wichita-backblasts.md
BIGQUERY_BACKBLAST_REVIEW_PATH=export/google/bigquery-backblast-export-review.json

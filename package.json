{
  "name": "slack-context-bot",
  "version": "1.0.0",
  "description": "Slack Socket Mode bot with OpenAI Responses API and vector store file search.",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "rag:setup": "node scripts/rag-setup.js",
    "rag:rebuild": "node scripts/rag-setup.js rebuild",
    "rag:add": "node scripts/rag-setup.js add",
    "backblasts:bigquery": "node scripts/export-backblasts-bigquery.js",
    "backblasts:bigquery:dry-run": "node scripts/export-backblasts-bigquery.js --dry-run",
    "youtube:export": "node scripts/export-youtube.js",
    "test": "node --check app.js && node --check scripts/rag-setup.js && node --check scripts/export-youtube.js && node --check scripts/export-backblasts-bigquery.js"
  },

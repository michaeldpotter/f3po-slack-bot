{
  "name": "slack-context-bot",
  "version": "1.0.0",
  "description": "Slack Socket Mode bot with OpenAI Responses API and vector store file search.",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "rag:setup": "node scripts/rag-setup.js",
    "rag:rebuild": "node scripts/rag-setup.js rebuild",
    "rag:add": "node scripts/rag-setup.js add",
    "rag:prune": "node scripts/rag-setup.js prune",
    "reporting:sync": "node scripts/sync-reporting-db.js",
    "reporting:sync:full": "node scripts/sync-reporting-db.js --full",
    "reporting:sync:dry-run": "node scripts/sync-reporting-db.js --dry-run",
    "reporting:query": "node scripts/query-reporting-db.js",
    "reporting:status": "node scripts/query-reporting-db.js status",
    "reporting:health": "node scripts/query-reporting-db.js health",
    "interactions:search": "node scripts/search-interactions.js",
    "youtube:export": "node scripts/export-youtube.js",
    "test": "node --check app.js && node --check scripts/rag-setup.js && node --check scripts/export-youtube.js && node --check scripts/sync-reporting-db.js && node --check scripts/query-reporting-db.js && node --check scripts/search-interactions.js && bash -n scripts/*.sh"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@google-cloud/bigquery": "^8.1.1",
    "@slack/bolt": "^4.6.0",
    "dotenv": "^17.3.1",
    "openai": "^6.27.0"
  }
}
